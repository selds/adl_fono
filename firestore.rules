rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isActiveUser() {
      return signedIn() &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isActive == true;
    }

    function isAdmin() {
      return signedIn() &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{uid} {
      // Apenas admin pode listar todos os usuários.
      allow list: if isAdmin();

      // O próprio usuário ou admin podem ler um perfil específico.
      allow get: if signedIn() && (request.auth.uid == uid || isAdmin());

      // Usuário cria apenas o próprio documento, sem poder se auto-promover a admin.
      allow create: if signedIn() && (
          (
            request.auth.uid == uid &&
            request.resource.data.uid == request.auth.uid &&
            request.resource.data.role == 'fonoaudiologo'
          ) ||
          (
            isAdmin() &&
            request.resource.data.uid == uid &&
            request.resource.data.role in ['admin', 'fonoaudiologo']
          )
        );

      // Admin pode alterar tudo; usuário comum só pode atualizar dados de perfil.
      allow update: if signedIn() && (
          isAdmin() ||
          (
            request.auth.uid == uid &&
            request.resource.data.uid == resource.data.uid &&
            request.resource.data.role == resource.data.role &&
            request.resource.data.isActive == resource.data.isActive
          )
        );

      allow delete: if isAdmin();
    }

    // Fichas de anamnese: usuários ativos autenticados podem operar.
    match /pacientes/{docId} {
      allow read, create, update, delete: if isActiveUser();
    }

    // Protocolos ADL: usuários ativos autenticados podem operar.
    match /adl_protocols/{docId} {
      allow read, create, update, delete: if isActiveUser();
    }

    // Logs de acesso: escrita no login para o próprio usuário, leitura apenas admin.
    match /access_logs/{docId} {
      allow create: if isActiveUser() &&
          request.resource.data.uid == request.auth.uid;
      allow get, list: if isAdmin();
      allow update, delete: if false;
    }
  }
}
